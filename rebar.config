%% -*- mode: erlang -*-
%% rebar3 configuration for macula_rag

{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    {macula, "~> 4.7"}
]}.

{project_plugins, [
    rebar3_hex,
    rebar3_ex_doc
]}.

{shell, [
    {apps, [macula_rag]}
]}.

{hex, [
    {name, macula_rag},
    {doc, #{provider => ex_doc}},
    {licenses, ["Apache-2.0"]},
    {links, #{
        <<"Codeberg">> => <<"https://codeberg.org/macula-io/macula-rag">>
    }},
    {description, "Federated semantic retrieval over the Macula mesh"}
]}.

{ex_doc, [
    {source_url, <<"https://codeberg.org/macula-io/macula-rag">>},
    {extras, ["README.md", "CHANGELOG.md", "LICENSE",
              "guides/getting_started.md", "guides/federation_design.md"]},
    {main, "README.md"}
]}.

{profiles, [
    {lint, [
        {plugins, [{rebar3_lint, "5.0.4"}]}
    ]}
]}.

{elvis, [
    {rulesets, #{
        macula_min => [
            {elvis_style, no_deep_nesting, #{level => 2}},
            {elvis_style, no_nested_try_catch, #{}},
            {elvis_style, no_if_expression, #{}}
        ]
    }},
    {config, [ #{files => ["src/**/*.erl"], ruleset => macula_min} ]}
]}.
